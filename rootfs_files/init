#!/bin/sh

# Mount essential filesystems
mount -t proc none /proc
mount -t sysfs none /sys
mount -t devtmpfs none /dev

echo "============================================"
echo "  ARM64 Embedded Linux Test Environment"
echo "  Built by Sohail Ali Hassan Abbasi"
echo "============================================"

# Load kernel modules if present
if [ -d /modules ]; then
    for mod in /modules/*.ko; do
        [ -f "$mod" ] && insmod "$mod" && echo "Loaded: $mod"
    done
fi

# Run test script if present
if [ -f /root/run_tests.sh ]; then
    sh /root/run_tests.sh
fi

# Drop to shell
exec /bin/sh
